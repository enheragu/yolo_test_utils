<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    :root {
      --bg: #f8f8f8;
      --fg: #222;
      --muted: #666;
      --accent: #2a5db0;
      --border: #d0d0d0;
      --card: #ffffff;
      --warn: #b05a00;
      --header-h: 0px;
      --tabs-h: 0px;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0; padding: 0; color: var(--fg); background: var(--bg);
      font-size: 14px; line-height: 1.45;
    }
    header {
      background: var(--accent); color: white;
      padding: 20px 28px;
    }
    header h1 { margin: 0 0 4px 0; font-size: 22px; }
    header .sub { opacity: 0.9; font-size: 13px; }

    nav.tabs {
      background: var(--card); border-bottom: 1px solid var(--border);
      padding: 0 20px; display: flex; overflow-x: auto;
      position: sticky; top: 0; z-index: 10;
    }
    nav.tabs button {
      border: 0; background: transparent; cursor: pointer;
      padding: 12px 18px; font-size: 13px; font-weight: 500;
      color: var(--muted);
      border-bottom: 3px solid transparent;
      white-space: nowrap;
    }
    nav.tabs button:hover { color: var(--fg); background: rgba(0,0,0,0.03); }
    nav.tabs button.active {
      color: var(--accent); border-bottom-color: var(--accent);
    }

    main { padding: 24px 28px; max-width: 1600px; margin: 0 auto; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .controls { margin-bottom: 12px; font-size: 13px; }
    .controls a {
      color: var(--accent); text-decoration: none; margin-right: 12px; cursor: pointer;
    }
    .controls a:hover { text-decoration: underline; }

    iframe.slice {
      width: 100%;
      border: 0;
      background: transparent;
      min-height: calc(100vh - 180px);
      height: calc(100vh - 180px);
    }

    details {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 6px; margin-bottom: 14px;
    }
    details > summary {
      cursor: pointer; padding: 14px 18px; font-weight: 600;
      font-size: 15px; user-select: none;
    }
    details[open] > summary { border-bottom: 1px solid var(--border); }
    details .body { padding: 16px 18px; }

    p.note { color: var(--muted); font-style: italic; margin: 8px 0 14px; }
    h3 { margin: 18px 0 8px; font-size: 14px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }

    /* Cross-slice grid: N columns (one per slice). */
    .cross-grid {
      display: grid; gap: 12px; margin: 8px 0 18px;
      grid-template-columns: repeat({{ n_slices }}, minmax(0, 1fr));
    }
    .cross-grid .slice-col {
      display: flex; flex-direction: column; gap: 6px;
      min-width: 0;  /* allow child to shrink for overflow containers */
    }
    .cross-grid .slice-col > .slice-label {
      font-weight: 600; font-size: 12.5px; color: var(--accent);
      text-align: center;
    }
    .cross-grid figure {
      margin: 0; background: #fcfcfc; border: 1px solid var(--border);
      border-radius: 4px; padding: 6px;
    }
    .cross-grid img {
      max-width: 100%; height: auto; display: block;
      cursor: zoom-in;
    }
    .cross-grid .missing {
      color: var(--warn); font-style: italic; text-align: center;
      padding: 20px 8px; font-size: 12px;
    }

    .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 4px; background: var(--card); }
    .table-wrap table { margin: 0; border: 0; }
    table { border-collapse: collapse; font-size: 12px; width: 100%; }
    th, td { border: 1px solid var(--border); padding: 3px 6px; text-align: right; white-space: nowrap; }
    th { background: #eef0f4; font-weight: 600; text-align: center; position: sticky; top: 0; }
    td:first-child { text-align: left; font-family: ui-monospace, "SF Mono", Menlo, monospace; }

    /* Lightbox */
    #lightbox {
      position: fixed; inset: 0; background: rgba(0,0,0,0.88);
      display: none; align-items: center; justify-content: center;
      z-index: 9999; cursor: zoom-out; padding: 24px;
    }
    #lightbox.open { display: flex; }
    #lightbox img {
      max-width: 100%; max-height: 100%; object-fit: contain;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5); background: white;
    }
    #lightbox .cap {
      position: absolute; bottom: 12px; left: 0; right: 0;
      text-align: center; color: white; font-size: 13px;
      text-shadow: 0 1px 2px rgba(0,0,0,0.6);
    }
    #lightbox .close {
      position: absolute; top: 14px; right: 18px; color: white;
      font-size: 26px; line-height: 1; background: transparent; border: 0; cursor: pointer;
    }

    .tag-row { font-size: 12px; color: var(--muted); margin-bottom: 14px; }
    .tag-row code { background: #eef0f4; padding: 1px 5px; border-radius: 3px; }

    /* Full-zone embedded tab mode (single scrollbar, no nested-page chrome). */
    body.iframe-tab-active { overflow: hidden; }
    body.iframe-tab-active nav.tabs { position: sticky; top: 0; }
    body.iframe-tab-active main {
      padding: 0;
      max-width: none;
      margin: 0;
      height: calc(100vh - var(--header-h) - var(--tabs-h));
    }
    body.iframe-tab-active .tab-panel.active { height: 100%; }
    body.iframe-tab-active iframe.slice {
      min-height: 0;
      height: 100%;
    }

  </style>
</head>
<body>
  <header>
    <h1>{{ title }}</h1>
    <div class="sub">{{ subtitle }}</div>
  </header>

  <nav class="tabs" role="tablist">
    <button data-tab="cross" class="active">Cross-slice</button>
    {% for s in slices %}
    <button data-tab="{{ s.id }}">{{ s.label }}</button>
    {% endfor %}
  </nav>

  <main>
    <section id="tab-cross" class="tab-panel active">
      <div class="controls">
        <a onclick="document.querySelectorAll('#tab-cross details').forEach(d=>d.open=true)">Expand all</a>
        <a onclick="document.querySelectorAll('#tab-cross details').forEach(d=>d.open=false)">Collapse all</a>
      </div>
      <div class="tag-row">
        Generated: {{ generated_at }}
        &nbsp;|&nbsp; slices: {{ n_slices }}
        &nbsp;|&nbsp; target reducer: <code>{{ target_reducer }}</code>
        &nbsp;|&nbsp; equalization: <code>{{ equalization }}</code>
      </div>

      {% for section in cross_sections %}
      <details {% if section.open %}open{% endif %}>
        <summary>{{ section.title }}{% if section.badge %} — <span style="font-weight:400;color:var(--muted)">{{ section.badge }}</span>{% endif %}</summary>
        <div class="body">
          {% if section.description %}<p class="note">{{ section.description | safe }}</p>{% endif %}
          {% for row in section.rows %}
            {% if row.caption %}<h3>{{ row.caption }}</h3>{% endif %}
            <div class="cross-grid">
              {% for cell in row.cells %}
              <div class="slice-col">
                <div class="slice-label">{{ cell.slice_label }}</div>
                {% if cell.kind == "image" %}
                  {% if cell.src %}
                  <figure><img src="{{ cell.src }}" alt="{{ cell.caption }}" data-caption="{{ cell.caption }}"></figure>
                  {% else %}
                  <div class="missing">{{ cell.missing or "missing" }}</div>
                  {% endif %}
                {% elif cell.kind == "table" %}
                  {% if cell.html %}
                  <div class="table-wrap">{{ cell.html | safe }}</div>
                  {% else %}
                  <div class="missing">{{ cell.missing or "missing" }}</div>
                  {% endif %}
                {% endif %}
              </div>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </details>
      {% endfor %}
    </section>

    {% for s in slices %}
    <section id="tab-{{ s.id }}" class="tab-panel">
      <iframe class="slice" src="{{ s.href }}" title="{{ s.label }}"></iframe>
    </section>
    {% endfor %}
  </main>

  <div id="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
    <button class="close" aria-label="Close">&times;</button>
    <img src="" alt="">
    <div class="cap"></div>
  </div>

  <script>
    // Tabs
    (function () {
      const buttons = document.querySelectorAll("nav.tabs button");
      const panels = document.querySelectorAll(".tab-panel");
      const updateLayoutVars = function () {
        const header = document.querySelector("header");
        const tabs = document.querySelector("nav.tabs");
        const h = header ? header.offsetHeight : 0;
        const t = tabs ? tabs.offsetHeight : 0;
        document.documentElement.style.setProperty("--header-h", h + "px");
        document.documentElement.style.setProperty("--tabs-h", t + "px");
      };
      const setIframeMode = function (id) {
        document.body.classList.toggle("iframe-tab-active", id !== "cross");
        updateLayoutVars();
      };
      buttons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          const id = btn.getAttribute("data-tab");
          buttons.forEach(b => b.classList.remove("active"));
          panels.forEach(p => p.classList.remove("active"));
          btn.classList.add("active");
          const panel = document.getElementById("tab-" + id);
          if (panel) panel.classList.add("active");
          setIframeMode(id);
        });
      });
      setIframeMode("cross");
      window.addEventListener("resize", updateLayoutVars);
      updateLayoutVars();
    })();

    // Lightbox
    (function () {
      const lb = document.getElementById("lightbox");
      const lbImg = lb.querySelector("img");
      const lbCap = lb.querySelector(".cap");
      const close = function () {
        lb.classList.remove("open");
        lb.setAttribute("aria-hidden", "true");
      };
      document.querySelectorAll(".cross-grid img").forEach(function (img) {
        img.addEventListener("click", function () {
          lbImg.src = img.src;
          lbImg.alt = img.alt;
          lbCap.textContent = img.getAttribute("data-caption") || img.alt || "";
          lb.classList.add("open");
          lb.setAttribute("aria-hidden", "false");
        });
      });
      lb.addEventListener("click", close);
      lb.querySelector(".close").addEventListener("click", function (e) {
        e.stopPropagation(); close();
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") close();
      });
    })();
  </script>
</body>
</html>
